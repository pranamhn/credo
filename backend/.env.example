# Copy to .env and fill values before running

# Database
DATABASE_URL=postgresql+asyncpg://risklens:risklens@localhost:5432/risklens
DATABASE_URL_SYNC=postgresql://risklens:risklens@localhost:5432/risklens

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-in-production

# LLM fallback
ANTHROPIC_API_KEY=sk-ant-...

# Object storage (Cloudflare R2 / AWS S3)
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=risklens-statements
STORAGE_REGION=auto

# Feature flags
DEBUG=false
CONFIDENCE_THRESHOLD=0.85
MAX_FILE_SIZE_MB=50
